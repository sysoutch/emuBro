{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "emuBro",
  "version": "1.0.0-alpha.16",
  "identifier": "com.emubro.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "emuBro",
        "width": 1400,
        "height": 860,
        "minWidth": 980,
        "minHeight": 620,
        "resizable": true,
        "decorations": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "emuBro",
        "url": "/splashscreen.html",
        "width": 540,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "deb",
      "dmg",
      "app",
      "nsis",
      "msi"
    ],
    "resources": [
      "bundle-resources/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "shortDescription": "Retro game launcher for emulators",
    "category": "Game"
  }
}
