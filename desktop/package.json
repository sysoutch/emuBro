{
  "name": "emubro-desktop",
  "private": true,
  "version": "1.0.0-alpha.31",
  "type": "module",
  "scripts": {
    "build:legacy-ui": "npm --prefix .. run legacy:build",
    "cleanup:dev-ports": "node ../scripts/cleanup-dev-ports.js",
    "dev": "npm run build:legacy-ui && node ../scripts/sync-bundle-resources.js && vite",
    "dev:clean": "npm run cleanup:dev-ports && npm run dev",
    "build": "npm run build:legacy-ui && vite build",
    "preview": "vite preview",
    "desktop:dev": "npm run build:legacy-ui && node ../scripts/sync-bundle-resources.js && tauri dev",
    "desktop:dev:clean": "npm run cleanup:dev-ports && npm run desktop:dev",
    "desktop:build": "node ../scripts/sync-bundle-resources.js && node ../scripts/desktop-build.js",
    "desktop:build:linux:appimage": "node ../scripts/sync-bundle-resources.js && node ../scripts/build-linux-portable-appimage.js",
    "desktop:build:linux:flatpak": "node ../scripts/build-flatpak.js",
    "desktop:build:mac": "node ../scripts/sync-bundle-resources.js && tauri build --bundles app,dmg"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "emuBro": "file:..",
    "pinia": "^3.0.3",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "vite": "^7.1.7"
  }
}
