{
  "name": "emuBro",
  "version": "1.0.0-alpha.4",
  "description": " emuBro is an open source retro game launcher that associates your retro games with your emulators such as snes9x, epsxe, pcsx2, dolphin, cemu or whatever you like. ",
  "scripts": {
    "postinstall": "node -e \"console.log('Root postinstall: run `npm install` in `tauri/` and use `npm run dev` from root.')\"",
    "start": "npm run dev",
    "start:fast": "npm run dev",
    "dev": "npm --prefix tauri run tauri:dev",
    "dev:web": "npm --prefix tauri run dev",
    "build": "npm --prefix tauri run tauri:build",
    "build:web": "npm --prefix tauri run build",
    "prebuild:win": "taskkill /F /IM emuBro.exe /T || exit 0",
    "sync:resources": "node scripts/sync-emubro-resources.js",
    "sync:gamelist": "node scripts/sync-gamelist.js",
    "sync:assets": "npm run sync:resources && npm run sync:gamelist",
    "resources:manifest:update": "node scripts/update-resources-manifest.js"
  },
  "keywords": [
    "tauri",
    "vue",
    "pinia",
    "steam",
    "gaming",
    "app"
  ],
  "author": "sysout",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.11"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.6.2",
    "flag-icons": "^7.5.0",
    "gamepad.js": "^2.1.0"
  }
}
