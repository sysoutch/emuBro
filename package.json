{
  "name": "emuBro",
  "version": "1.0.0-alpha.19",
  "description": " emuBro is an open source retro game launcher that associates your retro games with your emulators such as snes9x, epsxe, pcsx2, dolphin, cemu or whatever you like. ",
  "scripts": {
    "postinstall": "node -e \"console.log('Root postinstall: run npm install in tauri/ and use npm run dev from root.')\"",
    "start": "npm run dev",
    "start:fast": "npm run dev",
    "cleanup:dev-ports": "node scripts/cleanup-dev-ports.js",
    "dev": "npm --prefix tauri run tauri:dev",
    "dev:web": "npm --prefix tauri run dev",
    "legacy:build": "webpack --config webpack.config.js",
    "legacy:watch": "webpack --config webpack.config.js --watch --mode development",
    "build": "npm --prefix tauri run tauri:build",
    "build:win:portable": "npm run sync:bundle-resources && node scripts/build-windows-portable.js",
    "build:linux:appimage": "npm --prefix tauri run tauri:build:linux:appimage",
    "build:linux:flatpak": "npm --prefix tauri run tauri:build:linux:flatpak",
    "build:mac": "npm --prefix tauri run tauri:build:mac",
    "build:web": "npm --prefix tauri run build",
    "prebuild:win": "taskkill /F /IM emuBro.exe /T || exit 0",
    "version:set": "node scripts/bump-version.js",
    "version:sync": "node scripts/bump-version.js sync",
    "sync:resources": "node scripts/sync-emubro-resources.js",
    "sync:gamelist": "node scripts/sync-gamelist.js",
    "sync:assets": "npm run sync:resources && npm run sync:gamelist",
    "sync:bundle-resources": "node scripts/sync-bundle-resources.js",
    "resources:manifest:update": "node scripts/update-resources-manifest.js"
  },
  "keywords": [
    "tauri",
    "vue",
    "pinia",
    "steam",
    "gaming",
    "app"
  ],
  "author": "sysout",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-loader": "^10.0.0",
    "concurrently": "^8.2.2",
    "css-loader": "^7.1.4",
    "nodemon": "^3.1.11",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "axios": "^1.13.2",
    "flag-icons": "^7.5.0",
    "gamepad.js": "^2.1.0"
  }
}
